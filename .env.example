# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# JWT Configuration (Generate a secure 64-character random string)
JWT_SECRET=REPLACE_WITH_64_CHARACTER_RANDOM_STRING
JWT_EXPIRE=7d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_GOLD_CIRCLE=price_your_gold_circle_price_id
STRIPE_PRICE_GOLD_CIRCLE_PLUS_10K=price_your_plus_plan_price_id
STRIPE_SETUP_GOLD_CIRCLE_PLUS_10K=price_your_plus_setup_price_id
STRIPE_PRICE_GOLD_CIRCLE_10K=price_your_10k_plan_price_id
STRIPE_SETUP_GOLD_CIRCLE_10K=price_your_10k_setup_price_id
git add server/controllers/subscriptionController.js client/src/pages/Subscription.jsx
git commit -m "Fix currency mismatch: change from GBP to USD for Stripe pricing"
git push







# Frontend URLs
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Master Admin Account (CHANGE IN PRODUCTION!)
MASTER_ADMIN_EMAIL=admin@yourcompany.com
MASTER_ADMIN_PASSWORD=CHANGEME_SECURE_PASSWORD

# Market Data API Keys (Sign up at respective providers)
TWELVE_DATA_API_KEY=your_twelve_data_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key
FINNHUB_API_KEY=your_finnhub_api_key
POLYGON_API_KEY=your_polygon_api_key

# Web Push Notifications (Generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourcompany.com

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Redis Configuration (Optional for caching)
REDIS_URL=redis://localhost:6379
